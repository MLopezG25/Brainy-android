<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Brainy" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary - Golden Yellow -->
        <item name="colorPrimary">@color/golden_primary</item>
        <item name="colorOnPrimary">@color/golden_on_primary</item>
        <item name="colorPrimaryContainer">@color/golden_primary_light</item>
        <item name="colorOnPrimaryContainer">@color/golden_primary_dark</item>

        <!-- Secondary - Warm Gold -->
        <item name="colorSecondary">@color/golden_secondary</item>
        <item name="colorOnSecondary">@color/golden_on_secondary</item>
        <item name="colorSecondaryContainer">@color/golden_secondary_light</item>
        <item name="colorOnSecondaryContainer">@color/golden_secondary_dark</item>

        <!-- Tertiary - Amber/Orange -->
        <item name="colorTertiary">@color/golden_tertiary</item>
        <item name="colorOnTertiary">@color/golden_on_tertiary</item>
        <item name="colorTertiaryContainer">@color/golden_tertiary_light</item>
        <item name="colorOnTertiaryContainer">@color/golden_tertiary_dark</item>

        <!-- Error -->
        <item name="colorError">@color/golden_error</item>
        <item name="colorOnError">@color/golden_on_error</item>

        <!-- Background -->
        <item name="android:colorBackground">@color/golden_background</item>
        <item name="colorOnBackground">@color/golden_on_background</item>

        <!-- Surface -->
        <item name="colorSurface">@color/golden_surface</item>
        <item name="colorOnSurface">@color/golden_on_surface</item>
        <item name="colorSurfaceVariant">@color/golden_surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/golden_on_surface_variant</item>

        <!-- Outline -->
        <item name="colorOutline">@color/golden_outline</item>
        <item name="colorOutlineVariant">@color/golden_outline_variant</item>

        <!-- Inverse -->
        <item name="colorSurfaceInverse">@color/golden_inverse_surface</item>
        <item name="colorOnSurfaceInverse">@color/golden_inverse_on_surface</item>
        <item name="colorPrimaryInverse">@color/golden_inverse_primary</item>
    </style>

    <style name="Theme.Brainy" parent="Base.Theme.Brainy" />
</resources>
